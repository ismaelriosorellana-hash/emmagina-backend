# ================================================================
# Mommy Crafts Backend — variables de entorno
# Copia este archivo como .env solo en tu computador.
# En Render crea las variables desde Environment. Nunca subas .env.
# ================================================================

# Servidor
NODE_ENV=development
PORT=3000
# Local: 0. Render: 1.
TRUST_PROXY_HOPS=0

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USUARIO:CONTRASENA@CLUSTER/NOMBRE_BASE_DATOS

# Seguridad de sesión
# Usa dos valores aleatorios diferentes, idealmente de 64 caracteres o más.
JWT_SECRET=REEMPLAZA_POR_UN_SECRETO_ALEATORIO_DE_64_CARACTERES
JWT_EXPIRES_IN=2h
JWT_ISSUER=mommy-crafts-api
JWT_AUDIENCE=mommy-crafts-frontend
SECURITY_LOG_SALT=REEMPLAZA_POR_OTRO_VALOR_ALEATORIO_DE_64_CARACTERES

# Orígenes autorizados. En producción deben usar HTTPS y no llevar rutas.
FRONTEND_URLS=https://mommycrafts.cl,https://www.mommycrafts.cl,https://mommycrafts.onrender.com
PUBLIC_FRONTEND_URL=https://mommycrafts.cl
PUBLIC_BACKEND_URL=https://mommy-crafts-backend.onrender.com

# SEO público y metadatos prerenderizados
# PUBLIC_SITE_URL: dominio público de la tienda que Google debe considerar como sitio principal.
# SEO_PUBLIC_URL: dominio que sirve las rutas /producto/:slug, /sitemap.xml y /robots.txt.
# Si configuras una rewrite en Render desde el frontend hacia el backend, puede ser igual a PUBLIC_SITE_URL.
PUBLIC_SITE_URL=https://mommycrafts.cl
SEO_PUBLIC_URL=https://mommycrafts.cl

# Se utilizan solamente al ejecutar npm run create-admin.
ADMIN_NAME=Administrador Mommy Crafts
ADMIN_EMAIL=administrador@mommycrafts.cl
ADMIN_PASSWORD=CAMBIA_ESTA_CONTRASENA

# Inventario
LOW_STOCK_LIMIT=5

# Cloudinary. Configura las tres variables o deja las tres vacías.
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_CUSTOMIZATION_FOLDER=mommy-crafts/personalizaciones
CLOUDINARY_SITE_FOLDER=mommy-crafts/sitio
CLOUDINARY_PAYMENT_FOLDER=mommy-crafts/pagos
CLOUDINARY_DESIGN_FOLDER=mommy-crafts/disenos

# Mercado Pago. Configura ambas credenciales o deja ambas vacías.
# MP_ENVIRONMENT puede ser test o production.
MP_ENVIRONMENT=test
MP_ACCESS_TOKEN=APP_USR_REEMPLAZA_CON_ACCESS_TOKEN
MP_WEBHOOK_SECRET=REEMPLAZA_CON_LA_CLAVE_SECRETA_WEBHOOK

# Pedidos por transferencia
TRANSFER_RECEIPT_HOURS=3

# Notificaciones de pedidos (opcional)
# Si no configuras RESEND_API_KEY, el sistema prepara mensajes y WhatsApp, pero no envía correos reales.
NOTIFICATIONS_ENABLED=true
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=Mommy Crafts <venta@mommycrafts.cl>
EMAIL_REPLY_TO=venta@mommycrafts.cl
EMAIL_LOGO_URL=https://res.cloudinary.com/jo3bgrnh/image/upload/v1782320550/LOGO_MOMMY_CRAFTS_PNGG_mpgyfl.png
NOTIFICATION_ADMIN_EMAIL=venta@mommycrafts.cl
WHATSAPP_SUPPORT_NUMBER=56954633848

# Modo pausa temporal de compras se controla desde Admin → Apariencia.
# Estos valores son fallback solo si aún no existe configuración en base de datos.
STORE_PAUSED=false
STORE_PAUSE_WHATSAPP=56954633848
STORE_PAUSE_MESSAGE=Nuestra tienda online estará disponible próximamente. Si necesitas consultar por un producto, escríbenos por WhatsApp.

# Analítica web (opcional)
# También puede administrarse desde Admin → Apariencia → Analítica.
# Déjalos vacíos hasta crear Google Analytics 4 y Microsoft Clarity.
ANALYTICS_ENABLED=false
GA4_MEASUREMENT_ID=
CLARITY_PROJECT_ID=
